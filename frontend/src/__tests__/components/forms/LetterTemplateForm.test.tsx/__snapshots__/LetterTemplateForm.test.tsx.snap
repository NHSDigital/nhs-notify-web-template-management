              >
                Turkish
              </option>
              <option
                value="ur"
              >
                Urdu
              </option>
              <option
                value="zh"
              >
                Chinese
              </option>
            </select>
          </div>
          <div>
            <span>
              Upload pdf 
            </span>
            <input
              accept="application/pdf"
              name="pdf"
              type="file"
            />
          </div>
          <div>
            <span>
              Upload csv 
            </span>
            <input
              accept="text/csv"
              name="csv"
              type="file"
            />
          </div>
          <button
            aria-disabled="false"
            class="nhsuk-button"
            id="create-nhs-app-template-submit-button"
            type="submit"
          >
            Save and upload
          </button>
        </form>
      </div>
    </div>
  </main>
</DocumentFragment>
